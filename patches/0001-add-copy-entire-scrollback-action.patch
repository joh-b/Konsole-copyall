From 2ec49edcf8b78c106756771fba51ac661ad7a8ab Mon Sep 17 00:00:00 2001
From: joh-b <77800599+joh-b@users.noreply.github.com>
Date: Thu, 16 Jul 2026 10:00:00 +0200
Subject: [PATCH] Add action to copy the entire scrollback

Add a dedicated terminal-display operation and expose it through the session
action collection.  The action intentionally has no default shortcut so that
users can choose one without changing Konsole's upstream defaults.

The implementation selects the same complete retained line range as the
existing Select All operation, but copies only to the regular clipboard.  It
does not invoke the primary-selection copy performed by selectAll().
---
 src/session/SessionController.cpp            |  4 ++++
 src/terminalDisplay/TerminalDisplay.cpp      | 11 +++++++++++
 src/terminalDisplay/TerminalDisplay.h        |  3 +++
 3 files changed, 18 insertions(+)

diff --git a/src/session/SessionController.cpp b/src/session/SessionController.cpp
--- a/src/session/SessionController.cpp
+++ b/src/session/SessionController.cpp
@@ -684,6 +684,10 @@ void SessionController::setupCommonActions()
     // disabled at first, since nothing has been selected now
     action->setEnabled(false);
 
+    action = collection->addAction(QStringLiteral("copy-entire-scrollback"), view().data(), &TerminalDisplay::copyAllToClipboard);
+    action->setText(i18n("Copy Entire Scrollback"));
+    action->setIcon(QIcon::fromTheme(QStringLiteral("edit-copy")));
+
     // We need a different QAction on the context menu because one will be disabled when there's no selection,
     // other will be hidden.
     action = collection->addAction(QStringLiteral("edit_copy_contextmenu"));
diff --git a/src/terminalDisplay/TerminalDisplay.cpp b/src/terminalDisplay/TerminalDisplay.cpp
--- a/src/terminalDisplay/TerminalDisplay.cpp
+++ b/src/terminalDisplay/TerminalDisplay.cpp
@@ -2503,6 +2503,17 @@ void TerminalDisplay::copyToClipboard(Screen::DecodingOptions options)
     QApplication::clipboard()->setMimeData(mimeData, QClipboard::Clipboard);
 }
 
+void TerminalDisplay::copyAllToClipboard()
+{
+    if (_screenWindow.isNull()) {
+        return;
+    }
+
+    _preserveLineBreaks = true;
+    _screenWindow->setSelectionByLineRange(0, _screenWindow->lineCount());
+    copyToClipboard();
+}
+
 void TerminalDisplay::pasteFromClipboard(bool appendEnter)
 {
     QString text;
diff --git a/src/terminalDisplay/TerminalDisplay.h b/src/terminalDisplay/TerminalDisplay.h
--- a/src/terminalDisplay/TerminalDisplay.h
+++ b/src/terminalDisplay/TerminalDisplay.h
@@ -455,6 +455,9 @@ public Q_SLOTS:
     /** Copies the selected text to the system clipboard. */
     void copyToClipboard(Screen::DecodingOptions options = Screen::PlainText);
 
+    /** Copies the complete available scrollback to the system clipboard. */
+    void copyAllToClipboard();
+
     /**
      * Pastes the content of the clipboard into the display.
      *
